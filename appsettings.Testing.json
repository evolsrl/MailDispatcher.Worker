{
  "ConnectionStrings": {
    "Master": "Server=TEST_DATA_BASE;Database=ERP_COMUN;user=USER_EVOL_WEB_AP;Password=ArecoPruebas2760;TrustServerCertificate=true",
    "TenantTemplate": "Server=TEST_DATA_BASE;Database={DATABASE};user=USER_EVOL_WEB_AP;Password=ArecoPruebas2760;TrustServerCertificate=true"
  },

  "Worker": {
    "PollSeconds": 60,
    "BatchSize": 10,
    "RunOnce": true,
    "IdMailEnvio": null
  },

  "Diagnostics": {
    "Enabled": true,
    "ShowTenantStartEnd": true,
    "ShowMailStartEnd": true,
    "ShowRecipients": true,
    "ShowProfileName": true,
    "ShowInlineImages": true,
    "ShowAttachments": true,
    "ShowSmtpSteps": true,
    "ShowElapsedMs": true
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "T:\\Logs\\MailDispatcher\\mail-dispatcher-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}